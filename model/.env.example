# Runtime overrides for the model baked into the Docker image.
# The Dockerfile already bakes this default GGUF into /models.
MODEL_REPO_ID=nvidia/NVIDIA-Nemotron-3-Nano-4B-GGUF
MODEL_FILENAME=NVIDIA-Nemotron3-Nano-4B-Q4_K_M.gguf
MODEL_NAME=aristotle-local
MODEL_DIR=/models
MODEL_CONTEXT_SIZE=32768
MODEL_THREADS=2
MODEL_PARALLEL=1
MODEL_PORT=7860
