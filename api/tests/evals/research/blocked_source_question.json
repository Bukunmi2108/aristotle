{
  "id": "blocked_source_question",
  "category": "blocked_source",
  "prompt": "Research renewable energy policy adoption where one candidate source is blocked, then summarize what can and cannot be verified.",
  "expectations": {
    "search": "required",
    "required_tools": ["search_web", "fetch_url"],
    "min_queries": 1,
    "min_fetched_urls": 2,
    "min_sources": 1,
    "min_failed_sources": 1,
    "min_citations": 1
  },
  "events": [
    {
      "type": "tool.started",
      "tool": "search_web",
      "input": {
        "query": "renewable energy policy report",
        "max_results": 3
      }
    },
    {
      "type": "tool.result",
      "tool": "search_web",
      "result_preview": [
        {
          "title": "Renewable energy policy report",
          "url": "https://example.org/energy-report",
          "domain": "example.org",
          "snippet": "A public report about renewable energy policy.",
          "status": "searched"
        }
      ]
    },
    {
      "type": "tool.started",
      "tool": "fetch_url",
      "input": {
        "url": "https://example.org/energy-report"
      }
    },
    {
      "type": "tool.result",
      "tool": "fetch_url",
      "result_preview": [
        {
          "title": "Renewable energy policy report",
          "url": "https://example.org/energy-report",
          "domain": "example.org",
          "snippet": "The report says policy incentives increased adoption.",
          "status": "fetched"
        }
      ]
    },
    {
      "type": "tool.started",
      "tool": "fetch_url",
      "input": {
        "url": "https://blocked.example.org/paywalled-report"
      }
    },
    {
      "type": "tool.result",
      "tool": "fetch_url",
      "result_preview": [
        {
          "title": "https://blocked.example.org/paywalled-report",
          "url": "https://blocked.example.org/paywalled-report",
          "domain": "blocked.example.org",
          "snippet": "403 Forbidden",
          "status": "failed"
        }
      ]
    },
    {
      "type": "message.completed",
      "message": "The fetched report supports that policy incentives increased adoption [1]. One candidate source was blocked, so that page was not verified from its body and remains uncertain."
    }
  ]
}
